generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  SOLO
  PRO
  TEAM
}

enum SubStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
}

model User {
  id              String           @id @default(uuid())
  email           String           @unique
  username        String           @unique
  passwordHash    String
  createdAt       DateTime         @default(now())
  boards          Board[]
  subscription    Subscription?
  usageTracking   UsageTracking?
  sessionMemories SessionMemory[]
  teamMemberships TeamMembership[]
}

model Board {
  id              String          @id @default(uuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  thumbnailUrl    String?
  isPublic        Boolean         @default(false)
  shareToken      String          @unique @default(uuid())
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  snapshots       BoardSnapshot[]
  sessionMemories SessionMemory[]
}

model SessionMemory {
  id          String   @id @default(uuid())
  userId      String
  boardId     String?
  createdAt   DateTime @default(now())
  summaryText String   @db.Text
  keyTopics   String[] @default([])
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  board       Board?   @relation(fields: [boardId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
}

model BoardSnapshot {
  id           String   @id @default(uuid())
  boardId      String
  board        Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  elementsJson Json
  createdAt    DateTime @default(now())
}

model Subscription {
  id                   String    @id @default(uuid())
  userId               String    @unique
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  plan                 Plan      @default(FREE)
  status               SubStatus @default(ACTIVE)
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  seatCount            Int       @default(1)
  teamId               String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model UsageTracking {
  id                           String   @id @default(uuid())
  userId                       String   @unique
  user                         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  boardsCreated                Int      @default(0)
  thinkingPartnerUsesThisMonth Int      @default(0)
  thinkingPartnerMonthReset    DateTime @default(now())
  challengeThinkingUsesToday   Int      @default(0)
  challengeDayReset            DateTime @default(now())
  sessionsCompleted            Int      @default(0)
  memorySessionsStored         Int      @default(0)
  updatedAt                    DateTime @updatedAt
}

model TeamMembership {
  id        String   @id @default(uuid())
  teamId    String
  userId    String
  role      String   @default("member")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
}
